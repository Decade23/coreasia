{
  "name": "landing",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.9",
  "engines": {
    "bun": ">=1.3.9"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "docker:dev": "docker compose up --build landing-dev",
    "docker:dev:watch": "docker compose up --build -d landing-dev && docker compose watch landing-dev",
    "docker:dev:logs": "docker compose logs -f landing-dev",
    "docker:dev:down": "docker compose down",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build -d landing-prod",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "@vueuse/motion": "^2.0.0",
    "canvas-confetti": "^1.9.4",
    "nuxt": "4.3.1",
    "three": "^0.182.0",
    "vite": "7.3.1",
    "vue": "3.5.27",
    "vue-router": "5.0.2"
  },
  "devDependencies": {
    "@iconify-json/bi": "^1.1.0",
    "@iconify-json/lucide": "^1.1.0",
    "@nuxt/eslint": "^0.7.2",
    "@nuxt/fonts": "0.13.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxtjs/seo": "3.4.0",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/three": "^0.182.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2"
  }
}
